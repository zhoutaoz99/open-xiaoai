# 大模型服务配置
# 注意：这几项就是原来 examples/migpt/.env 里的配置，直接搬过来即可

#你的大模型服务的 API 密钥
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

#接口地址（一般以 /v1 结尾，不包含 /chat/completions 部分）
OPENAI_BASE_URL=https://api.deepseek.com

#模型名称
OPENAI_MODEL=deepseek-v4-flash

#温度：取值 0-2，值越大回复越随机（删除该配置则使用服务商的默认值）
OPENAI_TEMPERATURE=1

#思考模式：true 开启，false 关闭（删除该配置则使用服务商的默认值）
#注意：这是 DeepSeek 的参数格式，其他服务商可能不支持，此时请删除该配置
#注意：开启思考模式后，上面的温度配置不生效
OPENAI_THINKING=false


# 数据库

#Postgres 连接串（本地跑 `pnpm db:up` 起一个就用这个默认值）
#注意：记忆库、对话轮次、提炼记录都在这里；灵魂和画像仍然是 data/ 下的 Markdown 文件
#注意：端口是 5433 不是 5432——开发机上常常已经有一个自己装的 Postgres 占着 5432
#      （Postgres.app、Homebrew 都默认它），docker-compose.yml 里特意错开了
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/assistant

#连接池上限
DATABASE_POOL_MAX=10


# 服务配置

#后端监听端口，需要和 migpt 的 AGENT_BASE_URL 对得上
ASSISTANT_PORT=8000

#监听地址
#注意：在 Docker 里运行时必须是 0.0.0.0，否则容器外访问不到
ASSISTANT_HOST=0.0.0.0

#API 密钥，需要和 migpt 的 AGENT_API_KEY 保持一致
#注意：删除该配置则不校验
ASSISTANT_API_KEY=

#灵魂文件：助手的性格、说话风格、边界（删除该配置则使用 data/soul.md）
#注意：系统永不改写它，只有你和前台能改；文件不存在时首次启动会自动生成一份模板
#注意：它不受 MEMORY_ENABLED 影响，人格不是记忆
ASSISTANT_SOUL_FILE=data/soul.md

#系统提示词（已废弃，建议改用上面的灵魂文件）
#注意：填了它会整体替换「灵魂 + 播报约束」，soul.md 就不生效了
ASSISTANT_SYSTEM_PROMPT=

#调用大模型失败时的兜底话术
ASSISTANT_ERROR_TEXT=我这边出了点问题，请稍后再试。


# 前台配置

#前台监听端口
WEB_PORT=3000

#前台去哪找后端
#注意：这是前台的**服务端**用的，不带 NEXT_PUBLIC_ 前缀，进不了浏览器。
#      浏览器只访问前台自己的 /api/*，由前台服务端代理转发并补上 ASSISTANT_API_KEY——
#      密钥不进浏览器。
ASSISTANT_API_URL=http://127.0.0.1:8000


# 多轮对话配置

#一轮对话最多记住多少问答（一轮 = 一问一答）
#注意：这是安全阀不是目标。真正决定对话有多长的是下面的闲置时间——
#      五分钟里说不到一百轮，绝大多数对话根本碰不到这个上限
ASSISTANT_MAX_TURNS=100

#闲置多少秒算这轮对话聊完，默认 300 秒（5 分钟）
#注意：到点做两件事——清空会话上下文、炼一版用户画像
ASSISTANT_SESSION_TTL_SECONDS=300

#命中这些关键词时清空**会话上下文**（英文逗号分隔）
#注意：这里清的是最近几轮对话，不碰长期记忆
#注意：默认值里原本有「清空记忆」，引入长期记忆后语义有歧义，已移除。
#      想清长期记忆请用下面的 MEMORY_WIPE_KEYWORDS
ASSISTANT_RESET_KEYWORDS=重新开始,忘掉刚才

#清空上下文后的回复话术
ASSISTANT_RESET_TEXT=好的，我们重新开始吧。


# 长期记忆配置

#记忆总开关：false 则回到纯内存版（灵魂照常生效）
MEMORY_ENABLED=true

#画像文件：助手对这个家的理解
#注意：记忆库和对话轮次已经进 Postgres 了，只有灵魂和画像还是文件——
#      它们是给人看、给人改的，Markdown 比数据库里的一个 text 列称手得多
MEMORY_PROFILE_FILE=data/profile.md

#对话轮次保留天数，设 0 则不落轮次（库里不留对话原文，前台的对话记录也会是空的）
MEMORY_TRANSCRIPT_DAYS=14

#提炼记录（每轮抽了什么、画像怎么改的）保留天数
#注意：这是给前台看的审计流水，不参与任何模型调用
MEMORY_EXTRACTION_DAYS=30

#单次检索最多返回多少条 / 结果长度预算（字）
MEMORY_RECALL_TOP_K=8
MEMORY_RECALL_MAX_CHARS=1500

#每个请求最多允许几轮带检索的模型往返（到了上限就强制作答，防止模型查完再查）
#注意：数的是往返轮次，不是检索条数——模型可能在一轮里并行查好几个词
MEMORY_SEARCH_MAX_CALLS=2

#检索时先播的填补话术（检索要多一次模型往返，干等着像卡死了）
#注意：置空则关闭
MEMORY_SEARCH_FILLER=让我想想。

#检索的传输方式：tools（标准 function calling）| marker（文本标记协议）
#注意：部分 OpenAI 兼容服务的流式工具调用不稳，那种情况下换成 marker，语义完全一样
MEMORY_RECALL_TRANSPORT=tools


# 画像巩固配置（把零散记忆消化成画像和习惯）

#画像预算（字）
MEMORY_PROFILE_MAX_CHARS=1000

#画像只在两个时机生成：
#  1. 每轮对话结束时（闲置 ASSISTANT_SESSION_TTL_SECONDS 秒后）
#  2. 每天下面这个点兜底一次，收拾等不到"对话结束"的残局（比如聊到一半重启了）
#两个时机都要求"有新记忆"才会真的跑，没有就空转跳过，不会重复生成。
#注意：本地时间，格式 HH:MM
MEMORY_CONSOLIDATE_AT=03:00

#命中这些关键词时清空**长期记忆**（画像、记忆库、对话轮次），灵魂不动
#注意：精确匹配整句，执行前会自动备份（画像备份成 data/*.bak，库里的数据备份成快照表）
MEMORY_WIPE_KEYWORDS=清空所有记忆

#清空长期记忆后的回复话术
MEMORY_WIPE_TEXT=好的，我已经把记住的事情都忘掉了。

#抽取记忆专用的大模型（删除这几项则复用上面的 OPENAI_* 配置）
#注意：抽取在后台异步跑，不占应答速度，可以配个便宜的模型
MEMORY_OPENAI_BASE_URL=
MEMORY_OPENAI_API_KEY=
MEMORY_OPENAI_MODEL=
