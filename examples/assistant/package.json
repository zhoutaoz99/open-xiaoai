{
  "name": "open-xiaoai-assistant",
  "version": "2.0.0",
  "description": "小爱音箱外部对话服务（有人格、有长期记忆，带管理前台）",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "pnpm -r build",
    "start": "pnpm --filter @assistant/api start",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
