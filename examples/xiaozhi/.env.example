# MiMo API 密钥（必填，ASR 和 TTS 共用）
# 在 https://platform.xiaomimimo.com/console/balance 获取
MIMO_API_KEY=

# === ASR 语音识别 ===
# 接口地址（默认：小米 MiMo）
# ASR_BASE_URL=https://api.xiaomimimo.com/v1
# 识别语言（zh=中文，auto=自动检测）
ASR_LANGUAGE=zh

# === TTS 语音合成 ===
# 接口地址（默认：小米 MiMo）
# TTS_BASE_URL=https://api.xiaomimimo.com/v1
# 模型名称（默认：mimo-v2.5-tts）
# TTS_MODEL=mimo-v2.5-tts
# 语音音色（默认：mimo_default）
# TTS_VOICE=mimo_default

# === Assistant 对话服务（大模型 agent） ===
# examples/assistant 模块的地址
ASSISTANT_BASE_URL=http://127.0.0.1:8000
# 会话 ID，同一会话共享多轮上下文
# ASSISTANT_SESSION_ID=default
# 鉴权密钥（可选，不配则不发送 Authorization 头）
# ASSISTANT_API_KEY=
# 是否使用流式 SSE 响应
# ASSISTANT_STREAM=true
# 首个事件超时（秒）
# ASSISTANT_TIMEOUT=30

# === 提醒推送服务 ===
# 监听端口（assistant 模块通过 POST /push 发送提醒）
# AGENT_PUSH_PORT=4400
# 监听地址（Docker 里需要 0.0.0.0）
# AGENT_PUSH_HOST=0.0.0.0
# 鉴权密钥（可选，不配则不校验）
# AGENT_PUSH_API_KEY=

# === 运行模式 ===
# 必设为 true，启用 KWS 和 VAD
CLI=true
